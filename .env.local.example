# Local Postgres (self-hosted, no cloud). Connects over the Unix socket as the
# current OS user (trust auth) — no password needed for local dev.
# Replace USER with your OS username; host=/tmp points at the brew Postgres socket.
DATABASE_URL=postgresql://USER@/bihar_scheme_tracker?host=/tmp

# Anthropic — for summaries/translations/embeddings (added in a later step).
ANTHROPIC_API_KEY=
